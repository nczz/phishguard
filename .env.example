# PhishGuard 環境變數設定
# 複製為 .env 後填入實際值

# 資料庫
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=phishguard
DB_PASS=phishguard_dev
DB_NAME=phishguard

# Redis
REDIS_ADDR=127.0.0.1:6379

# JWT
JWT_SECRET=change-me-to-a-random-string

# API Server
API_ADDR=:8080

# Tracker Server
TRACKER_ADDR=:8090
TRACKER_BASE_URL=http://localhost:8090

# 平台初始管理員（首次啟動自動建立）
ADMIN_EMAIL=admin@phishguard.local
ADMIN_PASSWORD=changeme123

# PhishGuard 環境變數設定
# 複製為 .env 後填入實際值

# ── 資料庫 ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=phishguard
DB_PASS=          # ⚠️ 必填，程式啟動時會檢查
DB_NAME=phishguard

# ── Redis ──
REDIS_ADDR=127.0.0.1:6379

# ── JWT ──
JWT_SECRET=       # ⚠️ 必填，請用 openssl rand -base64 32 產生

# ── API Server ──
# 後端 API 監聽地址（前端透過 Vite proxy 或 Nginx 轉發）
API_ADDR=:8080

# ── Tracker Server ──
# 追蹤伺服器監聽地址（處理開信/點擊/提交/舉報）
TRACKER_ADDR=:8090

# 追蹤伺服器的對外 URL（信件中的連結會指向這裡）
# 開發環境：http://localhost:8090
# 生產環境：https://t.yourdomain.com
TRACKER_BASE_URL=http://localhost:8090

# ── 平台初始管理員（首次啟動自動建立）──
ADMIN_EMAIL=admin@phishguard.local
ADMIN_PASSWORD=   # ⚠️ 必填，首次啟動建立管理員帳號的密碼

# ── 網域說明 ──
# 本系統需要兩個域名（或子域名）：
#
# 1. 應用域名（前端 + API）
#    開發：http://localhost:5173（Vite proxy 轉發 /api → :8080）
#    生產：https://app.yourdomain.com（Nginx 轉發）
#
# 2. 追蹤域名（Tracker Server）
#    開發：http://localhost:8090
#    生產：https://t.yourdomain.com
#    ⚠️ 這個域名會出現在釣魚信件的連結中，建議使用看起來正式的子域名
#
# 生產環境 DNS 設定：
#   app.yourdomain.com  → VPS IP
#   t.yourdomain.com    → VPS IP
#
# TRACKER_BASE_URL 必須設定為追蹤域名的完整 URL（含 https://）
# 信件中的追蹤連結、Landing Page、舉報連結都會使用這個 URL
